FROM node:alpine

LABEL org.opencontainers.image.authors="RSelvanTech"
LABEL org.opencontainers.image.title="Demo"

WORKDIR /app

COPY package.json .
RUN npm install

COPY app/ ./app/
RUN npm run build

RUN apk add --no-cache nginx
COPY nginx/nginx.conf /etc/nginx/nginx.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off"]


